---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'VoxMachina' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Voice-only conversational AI training with adaptive Bloom's taxonomy questioning." />
    <link rel="icon" type="image/svg+xml" href="/voxmachina/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 antialiased">
    <slot />
  </body>
</html>