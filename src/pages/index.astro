---
import Layout from '../layouts/Layout.astro';

const BARKER_ID = ''; // Fetched from API after PIN
const GOODWILL_ID = ''; // Fetched from API after PIN
---

<Layout title="VoxMachina — Voice AI Training">
  <style>
    /* iOS Safari fixes */
    .chat-container {
      height: 100dvh;
      padding-bottom: env(safe-area-inset-bottom, 0px);
    }
    .chat-messages {
      -webkit-overflow-scrolling: touch;
    }
    /* Prevent body scroll when chat is open */
    body.chat-open {
      overflow: hidden;
      position: fixed;
      width: 100%;
    }
  </style>

  <!-- ═══════ LANDING VIEW ═══════ -->
  <div id="landing-view" class="min-h-[100dvh] flex flex-col">
    <!-- Hero -->
    <header class="relative overflow-hidden border-b border-slate-800 shrink-0">
      <div class="absolute inset-0 bg-gradient-to-br from-blue-950/50 via-slate-950 to-violet-950/30"></div>
      <div class="relative mx-auto max-w-2xl px-4 py-10 text-center">
        <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-900/50 px-4 py-1.5 text-xs sm:text-sm text-slate-400">
          <span class="h-2 w-2 rounded-full bg-green-500 animate-pulse"></span>
          Powered by ElevenLabs Agents
        </div>
        <h1 class="bg-gradient-to-r from-blue-400 via-sky-300 to-violet-400 bg-clip-text text-4xl sm:text-6xl font-extrabold tracking-tight text-transparent">
          VoxMachina
        </h1>
        <p class="mt-4 text-base sm:text-lg text-slate-400 max-w-xl mx-auto">
          Voice-only conversational AI training. Practice sales pitches with an
          adaptive English customer, guided by a German mentor.
        </p>
      </div>
    </header>

    <!-- Phase Flow -->
    <section class="mx-auto max-w-2xl w-full px-4 py-6 shrink-0">
      <div class="flex items-center justify-center gap-1.5 sm:gap-4 text-xs sm:text-sm">
        <div id="phase-1" class="flex items-center gap-1.5 sm:gap-2 rounded-lg border border-blue-500 bg-blue-500/10 px-2.5 sm:px-4 py-1.5 sm:py-2 font-medium text-blue-300 transition-all">
          <span class="flex h-5 w-5 sm:h-6 sm:w-6 items-center justify-center rounded-full bg-blue-500 text-xs font-bold text-white">1</span>
          Briefing
        </div>
        <div class="h-px w-4 sm:w-12 bg-slate-700"></div>
        <div id="phase-2" class="flex items-center gap-1.5 sm:gap-2 rounded-lg border border-slate-700 bg-slate-900 px-2.5 sm:px-4 py-1.5 sm:py-2 text-slate-500 transition-all">
          <span class="flex h-5 w-5 sm:h-6 sm:w-6 items-center justify-center rounded-full bg-slate-700 text-xs font-bold text-white">2</span>
          Conversation
        </div>
        <div class="h-px w-4 sm:w-12 bg-slate-700"></div>
        <div id="phase-3" class="flex items-center gap-1.5 sm:gap-2 rounded-lg border border-slate-700 bg-slate-900 px-2.5 sm:px-4 py-1.5 sm:py-2 text-slate-500 transition-all">
          <span class="flex h-5 w-5 sm:h-6 sm:w-6 items-center justify-center rounded-full bg-slate-700 text-xs font-bold text-white">3</span>
          Reflection
        </div>
      </div>
      <p id="phase-hint" class="mt-4 text-center text-sm text-slate-500 px-2">
        Start with Ms. Goodwill — she'll brief you in German before the conversation.
      </p>
    </section>

    <!-- Agent Cards -->
    <section class="mx-auto max-w-2xl w-full px-4 pb-8 space-y-4 flex-1">
      <!-- Ms. Goodwill -->
      <div id="goodwill-card" class="rounded-2xl border border-slate-800 bg-slate-900/50 p-4 sm:p-6 backdrop-blur">
        <div class="flex items-start gap-4">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-violet-500/20 text-2xl">👩‍🏫</div>
          <div class="flex-1 min-w-0">
            <h2 class="text-lg sm:text-xl font-semibold text-violet-300">Ms. Goodwill</h2>
            <p class="text-sm text-slate-400 mt-0.5">German mentor — briefing & reflection</p>
            <p class="text-sm text-slate-500 mt-2 hidden sm:block">
              Bereitet dich auf das Gespräch vor und führt die Nachbesprechung durch.
            </p>
          </div>
        </div>
        <div class="flex gap-2 mt-4">
          <button data-agent="goodwill" data-action="start" class="flex-1 rounded-lg bg-violet-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-violet-500">
            Start Briefing
          </button>
          <button data-agent="goodwill" data-action="start-reflection" class="hidden rounded-lg border border-violet-500/50 px-5 py-2.5 text-sm font-medium text-violet-300 transition hover:bg-violet-500/10">
            Start Reflection
          </button>
        </div>
      </div>

      <!-- Mr. Barker -->
      <div id="barker-card" class="rounded-2xl border border-slate-800 bg-slate-900/50 p-4 sm:p-6 backdrop-blur opacity-50">
        <div class="flex items-start gap-4">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-blue-500/20 text-2xl">🧑‍💼</div>
          <div class="flex-1 min-w-0">
            <h2 class="text-lg sm:text-xl font-semibold text-blue-300">Mr. Barker</h2>
            <p class="text-sm text-slate-400 mt-0.5">English customer — adaptive sales practice</p>
            <p class="text-sm text-slate-500 mt-2 hidden sm:block">
              A senior buyer who asks adaptive questions. 10 questions per session.
            </p>
          </div>
        </div>
        <div class="mt-4">
          <button data-agent="barker" data-action="start" disabled class="w-full cursor-not-allowed rounded-lg bg-slate-700 px-5 py-2.5 text-sm font-medium text-slate-400">
            🔒 Locked
          </button>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-slate-800 py-4 text-center text-sm text-slate-600 shrink-0">
      <a href="https://github.com/wagemutig/voxmachina" class="hover:text-slate-400 transition">
        github.com/wagemutig/voxmachina
      </a>
    </footer>
  </div>

  <!-- ═══════ CHAT VIEW (full-screen overlay) ═══════ -->
  <div id="chat-view" class="chat-container hidden fixed inset-0 z-50 flex flex-col bg-slate-950">
    <!-- Chat Header -->
    <div class="shrink-0 border-b border-slate-800 bg-slate-900/80 backdrop-blur" style="padding-top: env(safe-area-inset-top, 0px);">
      <div class="flex items-center gap-3 px-4 py-3">
        <button id="chat-back-btn" class="shrink-0 rounded-lg p-2 text-slate-400 hover:bg-slate-800 transition">
          ←
        </button>
        <div id="chat-agent-icon" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-slate-800 text-xl">💬</div>
        <div class="flex-1 min-w-0">
          <h2 id="chat-agent-name" class="text-sm font-semibold text-slate-100 truncate">Agent</h2>
          <p id="chat-status" class="text-xs text-slate-500">Connecting…</p>
        </div>
        <div id="chat-mode-indicator" class="hidden shrink-0 items-center gap-1.5 rounded-full bg-slate-800 px-2.5 py-1 text-xs text-slate-400">
          <span class="h-1.5 w-1.5 rounded-full bg-slate-500"></span>
          <span id="chat-mode-text">Idle</span>
        </div>
        <button id="mute-btn" class="hidden shrink-0 rounded-lg bg-slate-800 p-2 text-slate-300 transition hover:bg-slate-700" title="Mute">
          🎙️
        </button>
      </div>
    </div>

    <!-- Chat Messages -->
    <div id="chat-messages" class="chat-messages flex-1 overflow-y-auto px-4 py-4 space-y-3">
      <p class="text-center text-sm text-slate-600">Connecting…</p>
    </div>

    <!-- Live Subtitle (voice mode only) -->
    <div id="subtitle-bar" class="hidden shrink-0 border-t border-slate-800 bg-slate-900/60 px-4 py-2">
      <p id="subtitle-text" class="text-sm text-slate-300 leading-relaxed break-words text-center"></p>
    </div>

    <!-- Chat Input -->
    <div class="shrink-0 border-t border-slate-800 bg-slate-900/80 backdrop-blur px-3 py-2" style="padding-bottom: max(env(safe-area-inset-bottom, 0px), 0.5rem);">
      <div class="flex items-end gap-2">
        <input
          id="text-input"
          type="text"
          placeholder="Type your message…"
          class="flex-1 min-w-0 rounded-2xl border border-slate-700 bg-slate-800 px-4 py-2.5 text-sm text-slate-100 placeholder-slate-500 focus:border-blue-500 focus:outline-none"
          autocomplete="off"
        />
        <button id="send-btn" class="shrink-0 rounded-2xl bg-blue-600 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-blue-500">
          Send
        </button>
      </div>
    </div>
  </div>

  <!-- ═══════ PIN GATE MODAL ═══════ -->
  <div id="pin-modal" class="hidden fixed inset-0 z-[70] flex items-center justify-center bg-black/70 backdrop-blur-sm p-4">
    <div class="w-full max-w-xs rounded-2xl border border-slate-700 bg-slate-900 p-6 text-center">
      <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-violet-500/20 text-2xl">🔒</div>
      <h3 class="text-lg font-semibold text-slate-100 mb-1">Access Code</h3>
      <p class="text-sm text-slate-500 mb-5">Enter PIN to start a conversation</p>
      <input
        id="pin-input"
        type="tel"
        inputmode="numeric"
        maxlength="4"
        placeholder="••••"
        class="w-full text-center text-2xl tracking-[0.5em] rounded-xl border border-slate-700 bg-slate-800 px-4 py-3 text-slate-100 placeholder-slate-600 focus:border-violet-500 focus:outline-none"
        autocomplete="off"
      />
      <p id="pin-error" class="hidden text-xs text-red-400 mt-2">Wrong PIN. Try again.</p>
      <button id="pin-submit" class="mt-4 w-full rounded-xl bg-violet-600 px-5 py-3 text-sm font-medium text-white transition hover:bg-violet-500">
        Unlock
      </button>
      <button id="pin-cancel" class="mt-3 w-full text-center text-sm text-slate-500 hover:text-slate-300 transition">
        Cancel
      </button>
    </div>
  </div>

  <!-- ═══════ MODE CHOICE MODAL ═══════ -->
  <div id="mode-modal" class="hidden fixed inset-0 z-[60] flex items-center justify-center bg-black/60 backdrop-blur-sm p-4">
    <div class="w-full max-w-sm rounded-2xl border border-slate-700 bg-slate-900 p-6">
      <h3 class="text-lg font-semibold text-slate-100 text-center mb-1">Start Conversation</h3>
      <p id="modal-agent-name" class="text-sm text-slate-400 text-center mb-6">Choose how you want to talk</p>
      <div class="space-y-3">
        <button id="voice-btn" class="w-full flex items-center gap-3 rounded-xl border border-slate-700 bg-slate-800 p-4 transition hover:border-blue-500 hover:bg-slate-750">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-blue-500/20 text-xl">🎙️</div>
          <div class="text-left flex-1">
            <div class="text-sm font-medium text-slate-100">Voice</div>
            <div class="text-xs text-slate-500">Talk with your microphone</div>
          </div>
        </button>
        <button id="text-btn" class="w-full flex items-center gap-3 rounded-xl border border-slate-700 bg-slate-800 p-4 transition hover:border-violet-500 hover:bg-slate-750">
          <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-violet-500/20 text-xl">⌨️</div>
          <div class="text-left flex-1">
            <div class="text-sm font-medium text-slate-100">Text only</div>
            <div class="text-xs text-slate-500">No microphone needed</div>
          </div>
        </button>
      </div>
      <button id="modal-cancel" class="mt-4 w-full text-center text-sm text-slate-500 hover:text-slate-300 transition">
        Cancel
      </button>
    </div>
  </div>

  <!-- ═══════ TRANSITION MODAL (Goodwill → Barker) ═══════ -->
  <div id="transition-modal" class="hidden fixed inset-0 z-[60] flex items-center justify-center bg-black/60 backdrop-blur-sm p-4">
    <div class="w-full max-w-sm rounded-2xl border border-slate-700 bg-slate-900 p-6 text-center">
      <div class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-blue-500/20 text-3xl">🧑‍💼</div>
      <h3 class="text-lg font-semibold text-slate-100 mb-1">Ready for Mr. Barker?</h3>
      <p class="text-sm text-slate-400 mb-6">Briefing complete. Now practice your sales pitch with Mr. Barker — he'll ask adaptive questions that adjust to your answers.</p>
      <button id="transition-continue" class="w-full rounded-xl bg-blue-600 px-5 py-3 text-sm font-medium text-white transition hover:bg-blue-500">
        Start Conversation →
      </button>
      <button id="transition-cancel" class="mt-3 w-full text-center text-sm text-slate-500 hover:text-slate-300 transition">
        Not now
      </button>
    </div>
  </div>

  <!-- ═══════ SCRIPT ═══════ -->
  <script type="module">
    import { Conversation } from 'https://esm.sh/@elevenlabs/client@1.11.2';

    const BARKER_ID = ''; // Fetched after PIN auth
    const GOODWILL_ID = ''; // Fetched after PIN auth
    let agentIds = { barker: '', goodwill: '' };

    // ── State ──────────────────────────
    let conversation = null;
    let currentAgentName = '';
    let currentAgentIcon = '';
    let currentAgentId = '';
    let currentPhase = 1; // 1=briefing, 2=conversation, 3=reflection
    let isTextMode = false;
    let isMuted = false;
    let agentPartialText = '';
    let lastTextMode = false; // remember user's mode preference

    // ── DOM refs ───────────────────────
    const landingView = document.getElementById('landing-view');
    const chatView = document.getElementById('chat-view');
    const chatMessages = document.getElementById('chat-messages');
    const chatAgentName = document.getElementById('chat-agent-name');
    const chatAgentIcon = document.getElementById('chat-agent-icon');
    const chatStatus = document.getElementById('chat-status');
    const chatModeIndicator = document.getElementById('chat-mode-indicator');
    const chatModeText = document.getElementById('chat-mode-text');
    const subtitleBar = document.getElementById('subtitle-bar');
    const subtitleText = document.getElementById('subtitle-text');
    const textInput = document.getElementById('text-input');
    const sendBtn = document.getElementById('send-btn');
    const muteBtn = document.getElementById('mute-btn');
    const chatBackBtn = document.getElementById('chat-back-btn');
    const modeModal = document.getElementById('mode-modal');
    const modalAgentName = document.getElementById('modal-agent-name');
    const voiceBtn = document.getElementById('voice-btn');
    const textBtn = document.getElementById('text-btn');
    const modalCancel = document.getElementById('modal-cancel');
    const transitionModal = document.getElementById('transition-modal');
    const transitionContinue = document.getElementById('transition-continue');
    const transitionCancel = document.getElementById('transition-cancel');
    const pinModal = document.getElementById('pin-modal');
    const pinInput = document.getElementById('pin-input');
    const pinError = document.getElementById('pin-error');
    const pinSubmit = document.getElementById('pin-submit');
    const pinCancel = document.getElementById('pin-cancel');
    let pinUnlocked = false;
    let pendingAgent = null; // { id, name, icon, phase }

    // ── Phase management ───────────────
    const phases = {
      1: { el: document.getElementById('phase-1'), hint: 'Start with Ms. Goodwill — she\'ll brief you in German before the conversation.' },
      2: { el: document.getElementById('phase-2'), hint: 'Now talk to Mr. Barker. He\'ll ask you 10 questions that adapt to your answers.' },
      3: { el: document.getElementById('phase-3'), hint: 'Back to Ms. Goodwill for reflection — discuss how the conversation went.' },
    };

    function setPhase(n) {
      Object.entries(phases).forEach(([num, p]) => {
        const isActive = Number(num) === n;
        p.el.className = isActive
          ? 'flex items-center gap-1.5 sm:gap-2 rounded-lg border border-blue-500 bg-blue-500/10 px-2.5 sm:px-4 py-1.5 sm:py-2 font-medium text-blue-300 transition-all'
          : 'flex items-center gap-1.5 sm:gap-2 rounded-lg border border-slate-700 bg-slate-900 px-2.5 sm:px-4 py-1.5 sm:py-2 text-slate-500 transition-all';
      });
      document.getElementById('phase-hint').textContent = phases[n].hint;
    }

    // ── Chat message rendering ────────
    function addChatMessage(speaker, text) {
      // Remove placeholder
      const placeholder = chatMessages.querySelector('.text-center');
      if (placeholder && placeholder.textContent.includes('Connecting')) placeholder.remove();

      const isAgent = speaker === 'agent';
      const wrapper = document.createElement('div');
      wrapper.className = `flex ${isAgent ? 'justify-start' : 'justify-end'}`;

      const bubble = document.createElement('div');
      bubble.className = isAgent
        ? 'max-w-[80%] rounded-2xl rounded-tl-sm bg-slate-800 px-4 py-2.5 text-sm text-slate-100 break-words'
        : 'max-w-[80%] rounded-2xl rounded-tr-sm bg-blue-600 px-4 py-2.5 text-sm text-white break-words';
      bubble.textContent = text;

      wrapper.appendChild(bubble);
      chatMessages.appendChild(wrapper);
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }

    function updateLiveSubtitle(text) {
      if (isTextMode) return;
      subtitleText.textContent = text;
    }

    // ── Show mode choice modal ────────
    function showModeChoice(agentId, agentName, agentIcon) {
      currentAgentId = agentId;
      currentAgentName = agentName;
      currentAgentIcon = agentIcon;
      modalAgentName.textContent = `${agentName} — choose how you want to talk`;
      modeModal.classList.remove('hidden');
      modeModal.classList.add('flex');
    }

    function hideModeChoice() {
      modeModal.classList.add('hidden');
      modeModal.classList.remove('flex');
    }

    // ── Start conversation ────────────
    async function startConversation(textMode) {
      isTextMode = textMode;

      // End any existing conversation
      if (conversation) {
        try { await conversation.endSession(); } catch (e) {}
      }

      agentPartialText = '';

      // Open chat view
      landingView.classList.add('hidden');
      chatView.classList.remove('hidden');
      chatView.classList.add('flex');
      document.body.classList.add('chat-open');

      chatAgentName.textContent = currentAgentName;
      chatAgentIcon.textContent = currentAgentIcon;
      chatStatus.textContent = 'Connecting…';
      chatMessages.innerHTML = '<p class="text-center text-sm text-slate-600">Connecting…</p>';

      // Show/hide mode-specific UI
      if (textMode) {
        subtitleBar.classList.add('hidden');
        muteBtn.classList.add('hidden');
        chatModeIndicator.classList.add('hidden');
      } else {
        subtitleBar.classList.remove('hidden');
        muteBtn.classList.remove('hidden');
        chatModeIndicator.classList.remove('hidden');
        chatModeIndicator.classList.add('flex');
      }

      try {
        const opts = {
          agentId: currentAgentId,
          textOnly: textMode,
          onConnect: () => {
            chatStatus.textContent = textMode ? 'Text chat' : 'Connected';
          },
          onDisconnect: () => {
            chatStatus.textContent = 'Disconnected';
            conversation = null;
            // If briefing just ended, show transition to Barker
            if (currentPhase === 1) {
              setTimeout(() => showTransition(), 300);
            }
          },
          onMessage: (message) => {
            if (message.source === 'user') {
              agentPartialText = '';
              addChatMessage('user', message.message);
            } else if (message.source === 'ai') {
              agentPartialText = '';
              updateLiveSubtitle('');
              addChatMessage('agent', message.message);
            }
          },
          onAgentChatResponsePart: (part) => {
            const text = typeof part === 'string' ? part : (part?.text || '');
            if (!text) return;
            agentPartialText += text;
            updateLiveSubtitle(agentPartialText);
          },
          onAgentResponseCorrection: (correction) => {
            if (correction?.corrected_agent_response) {
              updateLiveSubtitle(correction.corrected_agent_response);
            }
          },
          onError: (error) => {
            console.error('Conversation error:', error);
            chatStatus.textContent = `Error: ${error.message || error}`;
          },
          onStatusChange: (statusData) => {
            const status = statusData?.status || statusData;
            if (status === 'connected') {
              chatStatus.textContent = textMode ? 'Text chat' : 'Connected';
            } else if (status === 'connecting') {
              chatStatus.textContent = 'Connecting…';
            } else if (status === 'disconnected') {
              chatStatus.textContent = 'Disconnected';
            }
          },
          onModeChange: (modeData) => {
            if (isTextMode) return;
            const mode = modeData?.mode || modeData;
            if (mode === 'speaking') {
              chatAgentIcon.textContent = currentAgentIcon;
              chatModeText.textContent = 'Speaking';
              chatModeIndicator.querySelector('span').className = 'h-1.5 w-1.5 rounded-full bg-blue-400 animate-pulse';
            } else if (mode === 'listening') {
              chatAgentIcon.textContent = '👂';
              chatModeText.textContent = 'Listening';
              chatModeIndicator.querySelector('span').className = 'h-1.5 w-1.5 rounded-full bg-green-400 animate-pulse';
            }
          },
        };

        conversation = await Conversation.startSession(opts);
      } catch (err) {
        console.error('Failed to start conversation:', err);
        chatStatus.textContent = `Failed: ${err.message || err}`;
      }
    }

    // ── Close chat ────────────────────
    async function closeChat() {
      if (conversation) {
        try { await conversation.endSession(); } catch (e) {}
      }
      chatView.classList.add('hidden');
      chatView.classList.remove('flex');
      landingView.classList.remove('hidden');
      document.body.classList.remove('chat-open');
    }

    // ── Text input ────────────────────
    async function sendText() {
      const text = textInput.value.trim();
      if (!text || !conversation) return;

      agentPartialText = '';
      updateLiveSubtitle('');
      addChatMessage('user', text);
      textInput.value = '';

      try {
        await conversation.sendUserMessage(text);
      } catch (err) {
        console.error('Failed to send:', err);
      }
    }

    // ── Transition: Goodwill → Barker ───
    function showTransition() {
      // Close chat view, show landing behind modal
      chatView.classList.add('hidden');
      chatView.classList.remove('flex');
      landingView.classList.remove('hidden');
      document.body.classList.remove('chat-open');

      // Unlock Barker if still locked
      const barkerBtn = document.querySelector('button[data-agent="barker"]');
      if (barkerBtn.disabled) {
        barkerBtn.disabled = false;
        barkerBtn.textContent = 'Start Conversation';
        barkerBtn.className = 'w-full rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-blue-500';
        document.getElementById('barker-card').classList.remove('opacity-50');
      }

      // Show modal
      transitionModal.classList.remove('hidden');
      transitionModal.classList.add('flex');
    }

    function hideTransition() {
      transitionModal.classList.add('hidden');
      transitionModal.classList.remove('flex');
    }

    // ── Event listeners ───────────────
    sendBtn.addEventListener('click', sendText);
    textInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        e.preventDefault();
        sendText();
      }
    });
    textInput.addEventListener('input', () => {
      if (conversation) conversation.sendUserActivity();
    });

    chatBackBtn.addEventListener('click', closeChat);

    muteBtn.addEventListener('click', () => {
      if (!conversation || isTextMode) return;
      isMuted = !isMuted;
      try {
        conversation.setMicMuted(isMuted);
        muteBtn.textContent = isMuted ? '🔇' : '🎙️';
      } catch (e) {
        isMuted = !isMuted;
      }
    });

    // Mode choice buttons
    voiceBtn.addEventListener('click', () => {
      hideModeChoice();
      lastTextMode = false;
      startConversation(false);
    });
    textBtn.addEventListener('click', () => {
      hideModeChoice();
      lastTextMode = true;
      startConversation(true);
    });
    modalCancel.addEventListener('click', hideModeChoice);

    // Transition modal buttons
    transitionContinue.addEventListener('click', () => {
      hideTransition();
      setPhase(2);
      currentPhase = 2;
      showModeChoice(agentIds.barker, 'Mr. Barker', '🧑‍💼');
    });
    transitionCancel.addEventListener('click', () => {
      hideTransition();
    });

    // ── PIN gate ───────────────────────
    function requestPin(agent, agentName, agentIcon, phase) {
      if (pinUnlocked) {
        const id = agent === 'barker' ? agentIds.barker : agentIds.goodwill;
        currentPhase = phase;
        setPhase(phase);
        showModeChoice(id, agentName, agentIcon);
        return;
      }
      pendingAgent = { agent, name: agentName, icon: agentIcon, phase };
      pinError.classList.add('hidden');
      pinInput.value = '';
      pinModal.classList.remove('hidden');
      pinModal.classList.add('flex');
      setTimeout(() => pinInput.focus(), 100);
    }

    async function checkPin() {
      const entered = pinInput.value.trim();
      if (!entered) return;

      pinSubmit.textContent = 'Checking…';
      pinSubmit.disabled = true;
      pinError.classList.add('hidden');

      try {
        const resp = await fetch('/api/auth', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ pin: entered }),
        });

        const data = await resp.json();

        if (resp.ok && data.ok) {
          pinUnlocked = true;
          agentIds = data.agents;
          pinModal.classList.add('hidden');
          pinModal.classList.remove('flex');
          if (pendingAgent) {
            currentPhase = pendingAgent.phase;
            setPhase(pendingAgent.phase);
            const id = pendingAgent.agent === 'barker' ? agentIds.barker : agentIds.goodwill;
            showModeChoice(id, pendingAgent.name, pendingAgent.icon);
            pendingAgent = null;
          }
        } else {
          pinError.textContent = data.error || 'Wrong PIN';
          pinError.classList.remove('hidden');
          pinInput.value = '';
          pinInput.focus();
        }
      } catch (e) {
        pinError.textContent = 'Connection error. Try again.';
        pinError.classList.remove('hidden');
      } finally {
        pinSubmit.textContent = 'Unlock';
        pinSubmit.disabled = false;
      }
    }

    pinSubmit.addEventListener('click', checkPin);
    pinInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') { e.preventDefault(); checkPin(); }
    });
    pinCancel.addEventListener('click', () => {
      pinModal.classList.add('hidden');
      pinModal.classList.remove('flex');
      pendingAgent = null;
    });

    // Agent start buttons — PIN gate then mode choice
    document.querySelectorAll('button[data-action="start"]').forEach(btn => {
      btn.addEventListener('click', () => {
        const agent = btn.dataset.agent;
        if (agent === 'goodwill') {
          btn.classList.add('hidden');
          document.querySelector('button[data-action="start-reflection"]').classList.remove('hidden');
          requestPin('goodwill', 'Ms. Goodwill', '👩‍🏫', 1);
        }
        if (agent === 'barker') {
          btn.classList.add('hidden');
          document.getElementById('barker-card').classList.remove('opacity-50');
          requestPin('barker', 'Mr. Barker', '🧑‍💼', 2);
        }
      });
    });

    document.querySelector('button[data-action="start-reflection"]')?.addEventListener('click', () => {
      requestPin('goodwill', 'Ms. Goodwill', '👩‍🏫', 3);
    });

    // Auto-unlock Mr. Barker after 15s
    setTimeout(() => {
      const barkerBtn = document.querySelector('button[data-agent="barker"]');
      if (barkerBtn.disabled) {
        barkerBtn.disabled = false;
        barkerBtn.textContent = 'Start Conversation';
        barkerBtn.className = 'w-full rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-blue-500';
        document.getElementById('barker-card').classList.remove('opacity-50');
      }
    }, 15000);
  </script>
</Layout>
