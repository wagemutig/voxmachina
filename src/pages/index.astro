---
import Layout from '../layouts/Layout.astro';
import Auth from '../components/Auth.astro';
---

<Layout title="VoxMachina — Voice AI Training">
  <style>
    .chat-container { height: 100dvh; padding-bottom: env(safe-area-inset-bottom, 0px); }
    .chat-messages { -webkit-overflow-scrolling: touch; }
    body.chat-open { overflow: hidden; position: fixed; width: 100%; }
  </style>

  <!-- ═══════ AUTH COMPONENTS ═══════ -->
  <Auth />

  <!-- ═══════ LANDING VIEW ═══════ -->
  <div id="landing-view" class="min-h-[100dvh] flex flex-col">
    <!-- Hero -->
    <header class="relative overflow-hidden border-b border-slate-800 shrink-0">
      <div class="absolute inset-0 bg-gradient-to-br from-blue-950/50 via-slate-950 to-violet-950/30"></div>
      <div class="relative mx-auto max-w-2xl px-4 py-10 text-center">
        <div class="mb-3 inline-flex items-center gap-2 rounded-full border border-slate-700 bg-slate-900/50 px-4 py-1.5 text-xs sm:text-sm text-slate-400">
          <span class="h-2 w-2 rounded-full bg-green-500 animate-pulse"></span>
          Powered by ElevenLabs Agents
        </div>
        <h1 class="bg-gradient-to-r from-blue-400 via-sky-300 to-violet-400 bg-clip-text text-4xl sm:text-6xl font-extrabold tracking-tight text-transparent">
          VoxMachina
        </h1>
        <p class="mt-4 text-base sm:text-lg text-slate-400 max-w-xl mx-auto">
          Voice-only conversational AI training. Practice sales pitches with an
          adaptive English customer, guided by a German mentor.
        </p>
        <div id="auth-status-bar" class="mt-4 hidden">
          <button id="auth-signin-btn" class="inline-flex items-center gap-2 rounded-lg bg-blue-600/20 border border-blue-500/30 px-4 py-2 text-sm text-blue-300 hover:bg-blue-600/30 transition">
            Sign in to save conversations
          </button>
        </div>
      </div>
    </header>

    <!-- Phase Flow -->
    <section class="mx-auto max-w-2xl w-full px-4 py-6 shrink-0">
      <div class="flex items-center justify-center gap-1.5 sm:gap-4 text-xs sm:text-sm">
        <div id="phase-1" class="flex items-center gap-1.5 sm:gap-2 rounded-lg border border-blue-500 bg-blue-500/10 px-2.5 sm:px-4 py-1.5 sm:py-2 font-medium text-blue-300 transition-all">
          <span class="flex h-5 w-5 sm:h-6 sm:w-6 items-center justify-center rounded-full bg-blue-500 text-xs font-bold text-white">1</span>
          Briefing
        </div>
        <div class="h-px w-4 sm:w-12 bg-slate-700"></div>
        <div id="phase-2" class="flex items-center gap-1.5 sm:gap-2 rounded-lg border border-slate-700 bg-slate-900 px-2.5 sm:px-4 py-1.5 sm:py-2 text-slate-500 transition-all">
          <span class="flex h-5 w-5 sm:h-6 sm:w-6 items-center justify-center rounded-full bg-slate-700 text-xs font-bold text-white">2</span>
          Conversation
        </div>
        <div class="h-px w-4 sm:w-12 bg-slate-700"></div>
        <div id="phase-3" class="flex items-center gap-1.5 sm:gap-2 rounded-lg border border-slate-700 bg-slate-900 px-2.5 sm:px-4 py-1.5 sm:py-2 text-slate-500 transition-all">
          <span class="flex h-5 w-5 sm:h-6 sm:w-6 items-center justify-center rounded-full bg-slate-700 text-xs font-bold text-white">3</span>
          Reflection
        </div>
      </div>
      <p id="phase-hint" class="mt-4 text-center text-sm text-slate-500 px-2">
        Start with Ms. Goodwill — she'll brief you in German before the conversation.
      </p>
    </section>

    <!-- Agent Cards -->
    <section class="mx-auto max-w-2xl w-full px-4 pb-8 space-y-4 flex-1">
      <!-- Ms. Goodwill -->
      <div id="goodwill-card" class="rounded-2xl border border-slate-800 bg-slate-900/50 p-4 sm:p-6 backdrop-blur">
        <div class="flex items-start gap-4">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-violet-500/20 text-2xl">👩‍🏫</div>
          <div class="flex-1 min-w-0">
            <h2 class="text-lg sm:text-xl font-semibold text-violet-300">Ms. Goodwill</h2>
            <p class="text-sm text-slate-400 mt-0.5">German mentor — briefing & reflection</p>
            <p class="text-sm text-slate-500 mt-2 hidden sm:block">
              Bereitet dich auf das Gespräch vor und führt die Nachbesprechung durch.
            </p>
          </div>
        </div>
        <div class="flex gap-2 mt-4">
          <button data-agent="goodwill" data-action="start" class="flex-1 rounded-lg bg-violet-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-violet-500">
            Start Briefing
          </button>
          <button data-agent="goodwill" data-action="start-reflection" class="hidden rounded-lg border border-violet-500/50 px-5 py-2.5 text-sm font-medium text-violet-300 transition hover:bg-violet-500/10">
            Start Reflection
          </button>
        </div>
      </div>

      <!-- Mr. Barker -->
      <div id="barker-card" class="rounded-2xl border border-slate-800 bg-slate-900/50 p-4 sm:p-6 backdrop-blur opacity-50">
        <div class="flex items-start gap-4">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-blue-500/20 text-2xl">🧑‍💼</div>
          <div class="flex-1 min-w-0">
            <h2 class="text-lg sm:text-xl font-semibold text-blue-300">Mr. Barker</h2>
            <p class="text-sm text-slate-400 mt-0.5">English customer — adaptive sales practice</p>
            <p class="text-sm text-slate-500 mt-2 hidden sm:block">
              A senior buyer who asks adaptive questions. 10 questions per session.
            </p>
          </div>
        </div>
        <div class="mt-4">
          <button data-agent="barker" data-action="start" disabled class="w-full cursor-not-allowed rounded-lg bg-slate-700 px-5 py-2.5 text-sm font-medium text-slate-400">
            🔒 Locked
          </button>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-slate-800 py-4 text-center text-sm text-slate-600 shrink-0">
      <a href="https://github.com/wagemutig/voxmachina" class="hover:text-slate-400 transition">
        github.com/wagemutig/voxmachina
      </a>
    </footer>
  </div>

  <!-- ═══════ CHAT VIEW ═══════ -->
  <div id="chat-view" class="chat-container hidden fixed inset-0 z-50 flex flex-col bg-slate-950">
    <div class="shrink-0 border-b border-slate-800 bg-slate-900/80 backdrop-blur" style="padding-top: env(safe-area-inset-top, 0px);">
      <div class="flex items-center gap-3 px-4 py-3">
        <button id="chat-back-btn" class="shrink-0 rounded-lg p-2 text-slate-400 hover:bg-slate-800 transition">←</button>
        <div id="chat-agent-icon" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-slate-800 text-xl">💬</div>
        <div class="flex-1 min-w-0">
          <h2 id="chat-agent-name" class="text-sm font-semibold text-slate-100 truncate">Agent</h2>
          <p id="chat-status" class="text-xs text-slate-500">Connecting…</p>
        </div>
        <div id="chat-mode-indicator" class="hidden shrink-0 items-center gap-1.5 rounded-full bg-slate-800 px-2.5 py-1 text-xs text-slate-400">
          <span class="h-1.5 w-1.5 rounded-full bg-slate-500"></span>
          <span id="chat-mode-text">Idle</span>
        </div>
        <button id="mute-btn" class="hidden shrink-0 rounded-lg bg-slate-800 p-2 text-slate-300 transition hover:bg-slate-700" title="Mute">🎙️</button>
      </div>
    </div>

    <div id="chat-messages" class="chat-messages flex-1 overflow-y-auto px-4 py-4 space-y-3">
      <p class="text-center text-sm text-slate-600">Connecting…</p>
    </div>

    <div id="subtitle-bar" class="hidden shrink-0 border-t border-slate-800 bg-slate-900/60 px-4 py-2">
      <p id="subtitle-text" class="text-sm text-slate-300 leading-relaxed break-words text-center"></p>
    </div>

    <div class="shrink-0 border-t border-slate-800 bg-slate-900/80 backdrop-blur px-3 py-2" style="padding-bottom: max(env(safe-area-inset-bottom, 0px), 0.5rem);">
      <div class="flex items-end gap-2">
        <input id="text-input" type="text" placeholder="Type your message…"
          class="flex-1 min-w-0 rounded-2xl border border-slate-700 bg-slate-800 px-4 py-2.5 text-sm text-slate-100 placeholder-slate-500 focus:border-blue-500 focus:outline-none"
          autocomplete="off" />
        <button id="send-btn" class="shrink-0 rounded-2xl bg-blue-600 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-blue-500">Send</button>
      </div>
    </div>
  </div>

  <!-- ═══════ MODE CHOICE MODAL ═══════ -->
  <div id="mode-modal" class="hidden fixed inset-0 z-[60] flex items-center justify-center bg-black/60 backdrop-blur-sm p-4">
    <div class="w-full max-w-sm rounded-2xl border border-slate-700 bg-slate-900 p-6">
      <h3 class="text-lg font-semibold text-slate-100 text-center mb-1">Start Conversation</h3>
      <p id="mode-modal-subtitle" class="text-center text-sm text-slate-500 mb-5">Choose how you want to talk</p>
      <div class="space-y-3">
        <button id="mode-voice" class="w-full flex items-center gap-3 rounded-xl border border-slate-700 bg-slate-800/50 px-4 py-3 text-left transition hover:border-blue-500/50 hover:bg-slate-800">
          <span class="text-2xl">🎙️</span>
          <div>
            <p class="font-medium text-slate-200">Voice</p>
            <p class="text-xs text-slate-500">Talk with your microphone</p>
          </div>
        </button>
        <button id="mode-text" class="w-full flex items-center gap-3 rounded-xl border border-slate-700 bg-slate-800/50 px-4 py-3 text-left transition hover:border-blue-500/50 hover:bg-slate-800">
          <span class="text-2xl">⌨️</span>
          <div>
            <p class="font-medium text-slate-200">Text</p>
            <p class="text-xs text-slate-500">No microphone needed</p>
          </div>
        </button>
      </div>
      <button id="mode-cancel" class="mt-4 w-full rounded-lg border border-slate-700 px-4 py-2 text-sm text-slate-400 hover:bg-slate-800 transition">Cancel</button>
    </div>
  </div>

  <!-- ═══════ TRANSITION MODAL ═══════ -->
  <div id="transition-modal" class="hidden fixed inset-0 z-[60] flex items-center justify-center bg-black/70 backdrop-blur-sm p-4">
    <div class="w-full max-w-sm rounded-2xl border border-slate-700 bg-slate-900 p-6 text-center">
      <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-blue-500/20 text-2xl">🎉</div>
      <h3 class="text-lg font-semibold text-slate-100 mb-2">Conversation Complete!</h3>
      <p class="text-sm text-slate-400 mb-5">Ready to talk with Mr. Barker?</p>
      <div class="space-y-2">
        <button id="trans-continue" class="w-full rounded-xl bg-blue-600 px-5 py-3 text-sm font-medium text-white transition hover:bg-blue-500">Continue with Mr. Barker</button>
        <button id="trans-cancel" class="w-full rounded-xl border border-slate-700 px-5 py-3 text-sm text-slate-400 transition hover:bg-slate-800">Back to Menu</button>
      </div>
    </div>
  </div>

  <script type="module">
    import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';

    const SUPABASE_URL = 'https://beuvflymiodgodeqksyh.supabase.co';
    const SUPABASE_KEY = 'sb_publishable_BPIAtbeuvflymiodgodeqksyh';
    const supabase = createClient(SUPABASE_URL, SUPABASE_KEY, {
      auth: { autoRefreshToken: true, persistSession: true, detectSessionInUrl: true }
    });

    const BARKER_ID = 'agent_9601kvdjdvqefd99es8881mc4z9g';
    const GOODWILL_ID = 'agent_5001kvdjcj2ke88aenh6yq6wh02h';

    let currentUser = null;
    let currentConversationId = null;
    let conversationMessages = [];

    // ── Auth State ───────────────────────
    async function initAuth() {
      const { data: { session } } = await supabase.auth.getSession();
      if (session?.user) {
        currentUser = session.user;
        showUserMenu();
      } else {
        showAuthPrompt();
      }

      supabase.auth.onAuthStateChange((event, session) => {
        if (event === 'SIGNED_IN' && session?.user) {
          currentUser = session.user;
          showUserMenu();
          hideAuthModal();
        } else if (event === 'SIGNED_OUT') {
          currentUser = null;
          hideUserMenu();
          showAuthPrompt();
        }
      });
    }

    function showUserMenu() {
      document.getElementById('auth-status-bar').classList.add('hidden');
      const menu = document.getElementById('user-menu');
      menu.classList.remove('hidden');
      document.getElementById('user-email').textContent = currentUser.email;
    }

    function hideUserMenu() {
      document.getElementById('user-menu').classList.add('hidden');
    }

    function showAuthPrompt() {
      document.getElementById('auth-status-bar').classList.remove('hidden');
      hideUserMenu();
    }

    // ── Auth Modal ───────────────────────
    const authModal = document.getElementById('auth-modal');
    const authMagicForm = document.getElementById('auth-magic-link-form');
    const authPasswordForm = document.getElementById('auth-password-form');
    const authMagicSent = document.getElementById('auth-magic-sent');

    document.getElementById('auth-signin-btn').addEventListener('click', () => {
      authModal.classList.remove('hidden');
      authMagicForm.classList.remove('hidden');
      authPasswordForm.classList.add('hidden');
      authMagicSent.classList.add('hidden');
    });

    document.getElementById('auth-cancel').addEventListener('click', hideAuthModal);
    document.getElementById('auth-show-password').addEventListener('click', () => {
      authMagicForm.classList.add('hidden');
      authPasswordForm.classList.remove('hidden');
    });
    document.getElementById('auth-show-magic').addEventListener('click', () => {
      authPasswordForm.classList.add('hidden');
      authMagicForm.classList.remove('hidden');
    });

    function hideAuthModal() {
      authModal.classList.add('hidden');
    }

    // Magic Link
    document.getElementById('auth-send-magic-link').addEventListener('click', async () => {
      const email = document.getElementById('auth-email').value.trim();
      if (!email) return;

      const btn = document.getElementById('auth-send-magic-link');
      btn.textContent = 'Sending…';
      btn.disabled = true;

      const { error } = await supabase.auth.signInWithOtp({
        email,
        options: { emailRedirectTo: window.location.origin }
      });

      if (error) {
        alert('Error: ' + error.message);
        btn.textContent = 'Send Magic Link';
        btn.disabled = false;
      } else {
        authMagicForm.classList.add('hidden');
        authMagicSent.classList.remove('hidden');
      }
    });

    // Password Sign In
    document.getElementById('auth-signin-pw').addEventListener('click', async () => {
      const email = document.getElementById('auth-email-pw').value.trim();
      const password = document.getElementById('auth-password').value;
      if (!email || !password) return;

      const { error } = await supabase.auth.signInWithPassword({ email, password });
      if (error) alert('Error: ' + error.message);
    });

    // Password Sign Up
    document.getElementById('auth-signup-pw').addEventListener('click', async () => {
      const email = document.getElementById('auth-email-pw').value.trim();
      const password = document.getElementById('auth-password').value;
      if (!email || password.length < 6) {
        alert('Password must be at least 6 characters');
        return;
      }

      const { error } = await supabase.auth.signUp({ email, password });
      if (error) alert('Error: ' + error.message);
      else alert('Account created! You can now sign in.');
    });

    // User Menu
    document.getElementById('user-menu-btn').addEventListener('click', () => {
      document.getElementById('user-dropdown').classList.toggle('hidden');
    });

    document.getElementById('user-logout').addEventListener('click', async () => {
      await supabase.auth.signOut();
      document.getElementById('user-dropdown').classList.add('hidden');
    });

    document.getElementById('user-history').addEventListener('click', () => {
      document.getElementById('user-dropdown').classList.add('hidden');
      loadConversationHistory();
    });

    document.getElementById('history-close').addEventListener('click', () => {
      document.getElementById('history-sidebar').classList.add('translate-x-full');
      setTimeout(() => document.getElementById('history-sidebar').classList.add('hidden'), 300);
    });

    // ── Conversation History ─────────────
    async function loadConversationHistory() {
      const sidebar = document.getElementById('history-sidebar');
      sidebar.classList.remove('hidden');
      sidebar.classList.remove('translate-x-full');

      const list = document.getElementById('history-list');
      list.innerHTML = '<p class="text-center text-sm text-slate-500">Loading…</p>';

      const { data, error } = await supabase
        .from('conversations')
        .select('*')
        .order('created_at', { ascending: false });

      if (error) {
        list.innerHTML = `<p class="text-center text-sm text-red-400">Error: ${error.message}</p>`;
        return;
      }

      if (!data || data.length === 0) {
        list.innerHTML = '<p class="text-center text-sm text-slate-500">No conversations yet</p>';
        return;
      }

      list.innerHTML = data.map(conv => {
        const date = new Date(conv.created_at).toLocaleDateString();
        const agent = conv.agent === 'barker' ? '🧑‍💼 Mr. Barker' : '👩‍🏫 Ms. Goodwill';
        const msgCount = conv.messages?.length || 0;
        return `
          <div class="rounded-lg border border-slate-700 bg-slate-800/50 p-3 cursor-pointer hover:bg-slate-800 transition" data-conv-id="${conv.id}">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm font-medium text-slate-200">${agent}</span>
              <span class="text-xs text-slate-500">${date}</span>
            </div>
            <p class="text-xs text-slate-400">${msgCount} messages · ${conv.mode}</p>
            ${conv.summary ? `<p class="text-xs text-slate-500 mt-1 truncate">${conv.summary}</p>` : ''}
          </div>
        `;
      }).join('');
    }

    async function saveConversation() {
      if (!currentUser || !currentConversationId) return;

      const { error } = await supabase
        .from('conversations')
        .update({
          messages: conversationMessages,
          ended_at: new Date().toISOString()
        })
        .eq('id', currentConversationId);

      if (error) console.error('Save error:', error);
    }

    async function createConversation(agent, mode) {
      if (!currentUser) return null;

      const { data, error } = await supabase
        .from('conversations')
        .insert({
          user_id: currentUser.id,
          agent,
          mode,
          messages: []
        })
        .select('id')
        .single();

      if (error) {
        console.error('Create conversation error:', error);
        return null;
      }

      return data.id;
    }

    // ── Conversation Helpers ─────────────
    function addMessage(role, text) {
      const msg = { role, text, time: new Date().toISOString() };
      conversationMessages.push(msg);
      renderMessage(role, text);
      saveConversation();
      return msg;
    }

    function renderMessage(role, text) {
      const container = document.getElementById('chat-messages');
      const div = document.createElement('div');
      div.className = `flex ${role === 'user' ? 'justify-end' : 'justify-start'}`;
      div.innerHTML = `
        <div class="max-w-[80%] rounded-2xl px-4 py-2.5 text-sm ${
          role === 'user'
            ? 'bg-blue-600 text-white rounded-br-md'
            : 'bg-slate-800 text-slate-200 rounded-bl-md'
        }">
          ${escapeHtml(text)}
        </div>
      `;
      container.appendChild(div);
      container.scrollTop = container.scrollHeight;
    }

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    // ── Phase / UI ───────────────────────
    function setPhase(n) {
      for (let i = 1; i <= 3; i++) {
        const el = document.getElementById(`phase-${i}`);
        if (i === n) {
          el.className = 'flex items-center gap-1.5 sm:gap-2 rounded-lg border border-blue-500 bg-blue-500/10 px-2.5 sm:px-4 py-1.5 sm:py-2 font-medium text-blue-300 transition-all';
        } else if (i < n) {
          el.className = 'flex items-center gap-1.5 sm:gap-2 rounded-lg border border-green-500/50 bg-green-500/10 px-2.5 sm:px-4 py-1.5 sm:py-2 text-green-300 transition-all';
        } else {
          el.className = 'flex items-center gap-1.5 sm:gap-2 rounded-lg border border-slate-700 bg-slate-900 px-2.5 sm:px-4 py-1.5 sm:py-2 text-slate-500 transition-all';
        }
      }
      const hints = {
        1: "Start with Ms. Goodwill — she'll brief you in German before the conversation.",
        2: "You're talking with Mr. Barker. Answer his questions and practice your pitch.",
        3: "Ms. Goodwill leads the reflection. Discuss what went well and what to improve."
      };
      document.getElementById('phase-hint').textContent = hints[n] || '';
    }

    // ── ElevenLabs SDK ───────────────────
    let conversation = null;
    let isMuted = false;

    async function startConversation(agentId, agentName, agentIcon, mode) {
      const container = document.getElementById('chat-messages');
      container.innerHTML = '<p class="text-center text-sm text-slate-600">Connecting…</p>';
      document.getElementById('chat-view').classList.remove('hidden');
      document.body.classList.add('chat-open');
      document.getElementById('chat-agent-name').textContent = agentName;
      document.getElementById('chat-agent-icon').textContent = agentIcon;
      document.getElementById('chat-status').textContent = 'Connecting…';

      conversationMessages = [];
      const agent = agentId === BARKER_ID ? 'barker' : 'goodwill';
      currentConversationId = await createConversation(agent, mode);

      try {
        const module = await import('https://esm.sh/@elevenlabs/client@1.11.2');
        const { Conversation } = module;

        conversation = await Conversation.startSession({
          agentId,
          overrides: {
            agent: { language: agentId === GOODWILL_ID ? 'de' : 'en' }
          },
          onConnect: () => {
            document.getElementById('chat-status').textContent = mode === 'voice' ? 'Listening…' : 'Connected';
            document.getElementById('chat-mode-indicator').classList.remove('hidden');
            document.getElementById('chat-mode-indicator').classList.add('flex');
            document.getElementById('chat-mode-text').textContent = mode === 'voice' ? 'Voice' : 'Text';
            document.getElementById('chat-mode-indicator').querySelector('span').className = 'h-1.5 w-1.5 rounded-full bg-green-500';
          },
          onDisconnect: () => {
            document.getElementById('chat-status').textContent = 'Disconnected';
            document.getElementById('chat-mode-indicator').querySelector('span').className = 'h-1.5 w-1.5 rounded-full bg-slate-500';
            if (currentConversationId) saveConversation();
          },
          onMessage: ({ source, message }) => {
            const role = source === 'user' ? 'user' : 'agent';
            addMessage(role, message);
            if (mode === 'voice') {
              document.getElementById('subtitle-text').textContent = message;
              document.getElementById('subtitle-bar').classList.remove('hidden');
            }
          },
          onError: (err) => {
            console.error('ElevenLabs error:', err);
            document.getElementById('chat-status').textContent = 'Error';
          },
          onModeChange: ({ mode: newMode }) => {
            document.getElementById('chat-mode-text').textContent = newMode === 'speaking' ? 'Speaking…' : newMode === 'listening' ? 'Listening…' : 'Idle';
          }
        });

        if (mode === 'voice') {
          document.getElementById('mute-btn').classList.remove('hidden');
          document.getElementById('subtitle-bar').classList.remove('hidden');
        }

      } catch (err) {
        console.error('Failed to start:', err);
        container.innerHTML = `<p class="text-center text-sm text-red-400">Error: ${err.message}</p>`;
      }
    }

    function endConversation() {
      if (conversation) {
        conversation.endSession();
        conversation = null;
      }
      saveConversation();
      currentConversationId = null;
      conversationMessages = [];
      document.getElementById('chat-view').classList.add('hidden');
      document.body.classList.remove('chat-open');
      document.getElementById('mute-btn').classList.add('hidden');
      document.getElementById('subtitle-bar').classList.add('hidden');
    }

    // ── Event Listeners ──────────────────
    document.getElementById('chat-back-btn').addEventListener('click', endConversation);

    document.getElementById('send-btn').addEventListener('click', () => {
      const input = document.getElementById('text-input');
      const text = input.value.trim();
      if (!text || !conversation) return;
      conversation.sendUserMessage({ text });
      input.value = '';
    });

    document.getElementById('text-input').addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        document.getElementById('send-btn').click();
      }
    });

    document.getElementById('mute-btn').addEventListener('click', () => {
      if (!conversation) return;
      isMuted = !isMuted;
      if (isMuted) conversation.mute();
      else conversation.unmute();
      document.getElementById('mute-btn').textContent = isMuted ? '🔇' : '🎙️';
      document.getElementById('mute-btn').title = isMuted ? 'Unmute' : 'Mute';
    });

    // ── Mode Choice ──────────────────────
    let pendingAgent = null;
    let pendingAgentName = null;
    let pendingAgentIcon = null;
    let pendingPhase = null;

    function showModeChoice(agentId, agentName, agentIcon, phase) {
      pendingAgent = agentId;
      pendingAgentName = agentName;
      pendingAgentIcon = agentIcon;
      pendingPhase = phase;
      document.getElementById('mode-modal').classList.remove('hidden');
      document.getElementById('mode-modal-subtitle').textContent = `${agentName} — choose how you want to talk`;
    }

    document.getElementById('mode-voice').addEventListener('click', () => {
      document.getElementById('mode-modal').classList.add('hidden');
      if (pendingAgent) startConversation(pendingAgent, pendingAgentName, pendingAgentIcon, 'voice');
    });

    document.getElementById('mode-text').addEventListener('click', () => {
      document.getElementById('mode-modal').classList.add('hidden');
      if (pendingAgent) startConversation(pendingAgent, pendingAgentName, pendingAgentIcon, 'text');
    });

    document.getElementById('mode-cancel').addEventListener('click', () => {
      document.getElementById('mode-modal').classList.add('hidden');
      pendingAgent = null;
    });

    // ── Agent Start Buttons ──────────────
    document.querySelectorAll('button[data-action="start"]').forEach(btn => {
      btn.addEventListener('click', () => {
        const agent = btn.dataset.agent;
        if (!currentUser) {
          authModal.classList.remove('hidden');
          authMagicForm.classList.remove('hidden');
          authPasswordForm.classList.add('hidden');
          return;
        }
        if (agent === 'goodwill') {
          showModeChoice(GOODWILL_ID, 'Ms. Goodwill', '👩‍🏫', 1);
        } else if (agent === 'barker') {
          showModeChoice(BARKER_ID, 'Mr. Barker', '🧑‍💼', 2);
        }
      });
    });

    document.querySelectorAll('button[data-action="start-reflection"]').forEach(btn => {
      btn.addEventListener('click', () => {
        if (!currentUser) {
          authModal.classList.remove('hidden');
          authMagicForm.classList.remove('hidden');
          authPasswordForm.classList.add('hidden');
          return;
        }
        showModeChoice(GOODWILL_ID, 'Ms. Goodwill', '👩‍🏫', 3);
      });
    });

    // ── Transition Modal ─────────────────
    const transitionModal = document.getElementById('transition-modal');
    document.getElementById('trans-continue').addEventListener('click', () => {
      transitionModal.classList.add('hidden');
      setPhase(2);
      showModeChoice(BARKER_ID, 'Mr. Barker', '🧑‍💼', 2);
    });
    document.getElementById('trans-cancel').addEventListener('click', () => {
      transitionModal.classList.add('hidden');
    });

    // ── Init ─────────────────────────────
    initAuth();
    setPhase(1);
  </script>
</Layout>
