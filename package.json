{
  "name": "voxmachina",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Voice-only conversational AI training bot with ElevenLabs Agents",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "deploy": "echo 'Deploy via Vercel: npx vercel deploy --prod'",
  "deploy:gh-pages": "npm run build && npx gh-pages -d dist --dotfiles",
    "start:barker": "node src/index.js --agent barker",
    "start:goodwill": "node src/index.js --agent goodwill"
  },
  "keywords": [
    "elevenlabs",
    "voice-ai",
    "training",
    "conversational-ai"
  ],
  "license": "MIT",
  "dependencies": {
    "@astrojs/vercel": "^10.0.8",
    "astro": "^6.4.8"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "tailwindcss": "^4.0.0"
  }
}
